{
  "name": "linxcoresight",
  "version": "1.0.0",
  "description": "LinxCoreSight - IDE for LinxISA development, pyCircuit simulation, and hardware visualization",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "build:install": "bash scripts/build_install_app.sh",
    "build:vite": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite build && electron .",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck",
    "linxtrace:lint": "node scripts/linxtrace_cli.js lint",
    "linxtrace:stats": "node scripts/linxtrace_cli.js stats",
    "linxtrace:schema-check": "node scripts/linxtrace_cli.js schema-check",
    "linxtrace:first-failure": "node scripts/linxtrace_cli.js first-failure",
    "linxtrace:render-check": "node scripts/linxtrace_cli.js render-check",
    "linxtrace:control": "node scripts/linxtrace_cli.js control",
    "trace:lint": "node scripts/trace_lint.js",
    "trace:perf": "node scripts/trace_perf_check.js",
    "trace:smoke-tabs": "node scripts/trace_smoke_tabs.js"
  },
  "author": "zhoubot",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhoubot/LinxCoreSight.git"
  },
  "bugs": {
    "url": "https://github.com/zhoubot/LinxCoreSight/issues"
  },
  "homepage": "https://github.com/zhoubot/LinxCoreSight#readme",
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "clsx": "^2.1.0",
    "cytoscape": "^3.28.1",
    "cytoscape-dagre": "^2.5.0",
    "d3": "^7.8.5",
    "electron-log": "^5.1.1",
    "lucide-react": "^0.309.0",
    "monaco-editor": "^0.45.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-resizable-panels": "^2.0.0",
    "serialport": "^12.0.0",
    "tailwind-merge": "^2.2.0",
    "ws": "^8.19.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.zhoubot.linxcoresight",
    "productName": "LinxCoreSight",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "templates/**/*",
      "third_party/**/*",
      "THIRD_PARTY_NOTICES.md"
    ],
    "extraResources": [
      {
        "from": "toolchains",
        "to": "toolchains",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": "dmg",
      "icon": "public/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png"
    }
  }
}
