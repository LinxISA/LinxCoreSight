  "buildProfile": {
    "kind": "command",
    "build": {
      "command": "python3",
      "args": [
        "scripts/run_benchmark_demo.py",
        "--benchmark",
        "dhrystone",
        "--action",
        "build"
      ]
    },
    "run": {
